# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test

# Cursor
.cursorrules
.cursor/

# Output of the go coverage tool, specifically when used with LiteIDE
*.out
coverage
mergedcoverage
cover_sdk

# HTML coverage report generate by Go tests
coverage.html

# go test -cpuprofile / -memprofile (local bench artifacts)
*.pprof
loadverify-cpu

# SQLite database
chat.db
marchat.db

# Keystore files (contain private keys)
keystore.dat
*.keystore

# Logs
*.log

# IDE/editor files
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db

# Dependency directories (vendor/ is used in older Go projects)
vendor/ 
config.json
server_config.json

# Environment files
.env
.env.local
.env.production

# Ignore everything inside config except .gitkeep and *.go files
config/*
!config/.gitkeep
!config/*.go

# Release binaries
marchat-*

# Plugin binaries and archives
plugin/examples/*/echo
plugin/examples/*/*.zip
plugin/examples/*/*.exe
plugin/examples/*/*.so
plugin/examples/*/*.dylib
*.zip

# Build release
build-release.sh

# Local scratch / generated invites (may contain secrets)
tmp/

# Caddy proxy overrides (public IP / DNS); tracked template is deploy/caddy/proxy.env.example
deploy/caddy/proxy.env
