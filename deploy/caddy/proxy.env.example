# Copy to proxy.env (same directory) and customize; proxy.env is gitignored.
# Compose loads this example first, then merges optional proxy.env (overrides per key).
#
# Caddy expands {$MARCHAT_CADDY_EXTRA_HOSTS} in the Caddyfile.
# Leave empty for loopback-only TLS (localhost / 127.0.0.1).
# For internet or LAN clients, set e.g.:
# MARCHAT_CADDY_EXTRA_HOSTS=, 203.0.113.5
# Multiple: , 203.0.113.5, chat.example.com
#
# After changing: docker compose -f docker-compose.proxy.yml up -d --force-recreate

MARCHAT_CADDY_EXTRA_HOSTS=
